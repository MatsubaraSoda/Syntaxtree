        {
          "abbr": "S",
          "full_en": "Simple declarative clause",
          "zh": "简单陈述句",
          "desc": "不由(可能为空的)从属连词或 wh-词引导, 且没有主谓倒装的简单陈述句."
        },
        {
          "abbr": "SBAR",
          "full_en": "Subordinate clause",
          "zh": "从属从句",
          "desc": "由(可能为空的)从属连词引导的从句."
        },
        {
          "abbr": "SBARQ",
          "full_en": "Direct question",
          "zh": "直接疑问句",
          "desc": "由 wh-词或 wh-短语引导的直接疑问句. 间接疑问句和关系从句应标注为 SBAR, 而不是 SBARQ."
        },
        {
          "abbr": "SINV",
          "full_en": "Inverted declarative sentence",
          "zh": "倒装陈述句",
          "desc": "主语位于时态动词或情态动词之后的倒装陈述句."
        },
        {
          "abbr": "SQ",
          "full_en": "Inverted yes/no question",
          "zh": "倒装一般疑问句",
          "desc": "倒装的一般疑问句, 或 SBARQ 中 wh-短语之后的 wh-疑问句的主句部分."
        }
      ]
    },
